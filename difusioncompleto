ax.set_ylabel(r'Exponente $\alpha$')
ax.set_title('Difusión anómala')

for bar, val in zip(bars, alphas):

    ax.text(
        bar.get_x() + bar.get_width()/2,
        val + 0.02,
        f'{val:.2f}',
        ha='center'
    )


#Dimensión fractal


ax = axes[1]

D_frac = {
    n: 2 - resultados[n]['alpha']/2
    for n in nombres
}

vals_frac = [
    D_frac[n]
    for n in nombres
]

bars = ax.bar(
    nombres,
    vals_frac,
    color=[colores[n] for n in nombres],
    edgecolor='white',
    alpha=0.85
)

ax.axhline(
    1.5,
    color='k',
    linestyle='--',
    alpha=0.5
)

ax.set_ylabel(r'$D_f = 2 - \alpha/2$')
ax.set_title('Dimensión fractal')

for bar, val in zip(bars, vals_frac):

    ax.text(
        bar.get_x() + bar.get_width()/2,
        val + 0.02,
        f'{val:.2f}',
        ha='center'
    )


plt.tight_layout()

plt.savefig(
    '/content/resumen_difusion_final.png',
    dpi=300
)

