    cbar.set_label(r'$\tau$ [s]')

    ax.set_title(f'Comparación de cuantiles — {nombre_dataset}')
    ax.set_xlabel('Cuantiles teóricos')
    ax.set_ylabel('Cuantiles experimentales')

    ax.grid(alpha=0.3)

