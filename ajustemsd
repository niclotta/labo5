        "atrapada",
    ]

    resultados_D = {}

    print("difusión libre")
    for nombre in datasets_libres:
        msds = cargar_msds(nombre)
        if msds:
            D_arr = ajustar_difusion(msds, nombre)
            resultados_D[nombre] = D_arr

    print("trampa óptica")
    for nombre in datasets_trampa:
        msds = cargar_msds(nombre)
        if msds:
            ajustar_trampa(msds, nombre)

    print("einstein stokes")
    einstein_stokes(resultados_D)

